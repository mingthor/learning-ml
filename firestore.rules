rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "gaomingduke@gmail.com" && request.auth.token.email_verified == true));
    }

    // ===============================================================
    // Question Stats
    // ===============================================================
    match /question_stats/{questionId} {
      // Allow any authenticated user to read and update stats
      // In a real multi-user app, we might want to scope this per user,
      // but the request implies global stats for the app.
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && 
        request.resource.data.keys().hasAll(['viewCount', 'skipCount', 'updatedAt']) &&
        request.resource.data.viewCount is int &&
        request.resource.data.skipCount is int;
    }

    // ===============================================================
    // Users (for admin role check)
    // ===============================================================
    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }
  }
}
